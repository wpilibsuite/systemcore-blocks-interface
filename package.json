{
  "name": "system_core_blocks",
  "version": "0.1.0",
  "homepage": "/blocks",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@blockly/theme-dark": "^8.0.4",
    "@blockly/theme-deuteranopia": "^7.0.4",
    "@blockly/theme-highcontrast": "^7.0.4",
    "@blockly/theme-tritanopia": "^7.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "antd": "^6.4.3",
    "blockly": "^12.5.1",
    "i18next": "^26.3.0",
    "i18next-http-backend": "^4.0.0",
    "jszip": "^3.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-syntax-highlighter": "^16.1.1",
    "semver": "^7.8.1",
    "typescript": "^6.0.3",
    "web-vitals": "^5.3.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "package": "npm run build && npm run package:backend && npm run package:dist && npm run package:icon && npm run package:venv && npm run package:ipk",
    "package:icon": "cp packaging/blocks.png packaging/overlay/opt/blocks/",
    "package:ipk": "cd packaging && if [ \"$(uname)\" = \"Darwin\" ]; then bash buildmac.sh; else bash build.sh; fi",
    "package:backend": "rsync -a --exclude=venv backend/ packaging/overlay/opt/blocks/backend",
    "package:venv": "cd packaging && ./buildVenv.sh", 
    "package:dist": "rsync -a dist/ packaging/overlay/opt/blocks/dist",
    "test": "vitest",
    "gen": "node src/Blockly/gen.js",
    "dev": "vite",
    "tscheck": "npx tsc -b --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript-strict-plugin": "^2.4.4",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0"
  }
}
